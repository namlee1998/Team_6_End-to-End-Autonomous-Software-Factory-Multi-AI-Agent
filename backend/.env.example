# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-project-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-project-secret-key
SUPABASE_STORAGE_BUCKET=documents
SUPABASE_AVATAR_BUCKET=avatars

# Auth redirect after OAuth/email actions.
# Local example: http://localhost:5173/auth
# Production example: https://your-frontend.vercel.app/auth
SUPABASE_AUTH_REDIRECT_URL=http://localhost:5173/auth

# AI Agents
AGENTS_BASE_URL=http://localhost:8000

# Frontend URL (for CORS)
# Example: https://your-frontend.vercel.app
# Multiple origins are supported via comma-separated values.
FRONTEND_URL=http://localhost:5173

# Upload limits (bytes)
MAX_FILE_SIZE=10485760
USE_MOCK_AGENTS=true

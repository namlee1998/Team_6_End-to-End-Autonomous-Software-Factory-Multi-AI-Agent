# Custom LLM Provider (OpenAI-compatible API)
OPENAI_API_KEY=
OPENAI_API_BASE=
DEFAULT_MODEL=

# Server
PORT=8000
HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO

# Langfuse tracing for the Python agents service (optional)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Use the host matching your Langfuse project region.
LANGFUSE_HOST=https://cloud.langfuse.com
